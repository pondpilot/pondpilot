# Enable the read_stat DuckDB extension for SAS, SPSS, and Stata file support
VITE_DUCKDB_ALLOW_UNSIGNED_EXTENSIONS=true
VITE_READ_STAT_EXTENSION_URL=/duckdb-extensions/read_stat/read_stat.duckdb_extension.wasm

# Polly AI proxy URL (default: https://ai-proxy.pondpilot.io)
# VITE_POLLY_PROXY_URL=https://ai-proxy.pondpilot.io

# CORS proxy URL (default: http://localhost:3000 dev; https://cors-proxy.pondpilot.io production)
# VITE_CORS_PROXY_URL=

# Slack bug-report proxy URL (default: unset; bug reporting is disabled)
# VITE_BUG_REPORT_PROXY_URL=

# DuckDB-WASM main module override (default: package-pinned jsDelivr bundle)
# VITE_DUCKDB_WASM_MAIN_MODULE=

# DuckDB-WASM main worker override (default: package-pinned jsDelivr bundle)
# VITE_DUCKDB_WASM_MAIN_WORKER=

# DuckDB-WASM pthread worker override (default: unset; uses DuckDB-WASM defaults)
# VITE_DUCKDB_WASM_PTHREAD_WORKER=

# Force the DuckDB-WASM MVP bundle (default: false)
# VITE_DUCKDB_WASM_FORCE_MVP=false

# Log every DuckDB query in development (default: false)
# VITE_DUCKDB_LOG_QUERIES=false

# Quack extension artifact override (default: official v1.5.2 WASM artifact)
# VITE_QUACK_WASM_EXTENSION_URL=
