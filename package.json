{
  "name": "pondpilot",
  "private": true,
  "version": "0.10.0",
  "description": "Get your data ducks in a row - a fast data exploration tool using DuckDB",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/pondpilot/pondpilot.git"
  },
  "author": "T1A",
  "contributors": [
    "Andrii Butko <andrii.butko@t1a.com>",
    "Mike Perlov <mike.perlov@t1a.com>"
  ],
  "homepage": "https://app.pondpilot.io",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "build:test": "yarn build --mode int-test-build",
    "test": "yarn build:test && playwright test",
    "test:no-build": "playwright test",
    "test:docker": "./docker-playwright.sh test",
    "test:unit": "jest",
    "test:unit:coverage": "jest --coverage",
    "test:all": "yarn test:unit && yarn test",
    "preview": "yarn build --mode int-test-build && vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "yarn lint:eslint && yarn lint:stylelint",
    "lint:fix": "yarn lint:eslint:fix && yarn lint:stylelint:fix",
    "lint:eslint": "eslint . --ext .ts,.tsx --cache",
    "lint:eslint:fix": "eslint . --ext .ts,.tsx --cache --fix",
    "lint:stylelint": "stylelint '**/*.css' --cache",
    "lint:stylelint:fix": "stylelint '**/*.css' --cache --fix",
    "prettier": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "readstat:install": "node scripts/install-readstat-wasm.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@duckdb/duckdb-wasm": "1.33.1-dev53.0",
    "@mantine/core": "8.2.3",
    "@mantine/hooks": "8.2.3",
    "@mantine/modals": "8.2.3",
    "@mantine/notifications": "8.2.3",
    "@mantine/spotlight": "8.2.3",
    "@monaco-editor/react": "4.7.0",
    "@pondpilot/flowscope-core": "0.4.2",
    "@tabler/icons-react": "3.44.0",
    "@tanstack/react-table": "8.21.3",
    "allotment": "1.20.5",
    "apache-arrow": "17.0.0",
    "clsx": "2.1.1",
    "comlink": "4.4.2",
    "fflate": "0.8.3",
    "idb": "8.0.3",
    "jszip": "3.10.1",
    "match-sorter": "8.3.0",
    "monaco-editor": "0.52.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "4.1.2",
    "react-icons": "5.7.0",
    "react-is": "19.2.7",
    "react-markdown": "10.1.0",
    "react-router-dom": "6.30.0",
    "reactflow": "11.11.4",
    "recharts": "3.9.2",
    "sql-formatter": "15.8.2",
    "tailwind-merge": "2.6.1",
    "uuid": "11.1.1",
    "vite-plugin-pwa": "0.21.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-is": "19.2.0",
    "@types/wicg-file-system-access": "2023.10.7",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.5.2",
    "eslint": "8.57.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-config-mantine": "3.2.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-local-rules": "3.0.2",
    "eslint-plugin-playwright": "2.10.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "http-server": "14.1.1",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jsdom": "24.1.3",
    "postcss": "8.5.16",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "prettier": "3.9.5",
    "prop-types": "15.8.1",
    "stylelint": "16.16.0",
    "stylelint-config-standard-scss": "13.1.0",
    "tailwindcss": "3.4.17",
    "ts-jest": "29.4.11",
    "typescript": "5.8.2",
    "vite": "5.4.21",
    "vite-plugin-svgr": "4.3.0",
    "vite-tsconfig-paths": "4.3.2",
    "wrangler": "4.110.0"
  },
  "resolutions": {
    "serialize-javascript": "7.0.5",
    "lodash": "4.18.1",
    "flatted": "3.4.2",
    "tar": "7.5.13",
    "picomatch": "4.0.4",
    "vite/rollup": "4.60.1"
  },
  "packageManager": "yarn@4.4.0"
}
